# ============================================================
# .env.production.example — Template untuk production server
# SALIN file ini ke .env.production di server, lalu isi nilainya
# JANGAN commit .env.production ke Git!
# ============================================================

# --- App ---
NODE_ENV=production
BETTER_AUTH_URL=https://yourdomain.com       # Ganti dengan domain kamu
BETTER_AUTH_SECRET=                          # generate: openssl rand -base64 32

# --- Database (Postgres) ---
POSTGRES_USER=lizzeyyoo
POSTGRES_PASSWORD=                           # password kuat, min 32 karakter
POSTGRES_DB=lizzeyyoo_db
DATABASE_URL=postgresql://lizzeyyoo:GANTI_PASSWORD@db:5432/lizzeyyoo_db

# --- Redis ---
REDIS_PASSWORD=                              # password kuat
REDIS_URL=redis://default:GANTI_PASSWORD@redis:6379

# --- AI Providers ---
GEMINI_API_KEY=                              # dari https://aistudio.google.com/app/apikey
OPENROUTER_API_KEY=                          # dari https://openrouter.ai/keys (opsional)
